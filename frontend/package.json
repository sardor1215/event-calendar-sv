  },
  "scripts": {
    "start": "react-scripts start",
    "dev": "react-scripts start",
    "start:https": "HTTPS=true SSL_CRT_FILE=server.crt SSL_KEY_FILE=server.key react-scripts start",
    "start:https-win": "set HTTPS=true && set SSL_CRT_FILE=server.crt && set SSL_KEY_FILE=server.key && react-scripts start",
    "build": "react-scripts build && node scripts/update-cache-version.js",
    "serve": "serve -s build -l 3000 -n --host 0.0.0.0",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.6"
